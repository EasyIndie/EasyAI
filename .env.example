APP_ENV=development

# OneAPI Gateway
ONEAPI_PORT=8080
ONEAPI_LOG_LEVEL=info
ONEAPI_ADMIN_USER=admin
ONEAPI_ADMIN_PASS=admin

# Auth
ONEAPI_AUTH_MODE=apikey,oauth
ONEAPI_API_KEYS=dev-key
ONEAPI_OAUTH_JWKS_URL=
ONEAPI_OAUTH_AUDIENCE=
ONEAPI_OAUTH_ISSUER=

# Upstreams (comma-separated base URLs)
ONEAPI_UPSTREAMS=http://litellm:4000
ONEAPI_UPSTREAM_TIMEOUT_MS=20000

# Cache (Redis)
REDIS_URL=redis://redis:6379
ONEAPI_CACHE_ENABLED=1
ONEAPI_CACHE_TTL_SECONDS=60
ONEAPI_CACHE_REPLAY_MODE=fixed
ONEAPI_CACHE_REPLAY_CHUNK_DELAY_MS=0
ONEAPI_CACHE_REPLAY_MAX_TOTAL_MS=0

# Rate limiting
ONEAPI_RATE_LIMIT_RPM=120

# Request/response transformation
ONEAPI_MODEL_MAP={}

# Guardrails (optional)
ONEAPI_GUARDRAILS_ENABLED=0
ONEAPI_GUARDRAILS_BLOCK_INTERNAL_IP=1
ONEAPI_GUARDRAILS_INJECTION_KEYWORDS=ignore all previous instructions,system prompt,developer message,jailbreak
ONEAPI_GUARDRAILS_PII_MASK_ENABLED=1

# Batch (optional, required to enable /v1/batches)
ONEAPI_INTERNAL_TOKEN=
ONEAPI_BASE_URL=http://oneapi:8080

# Analytics (Postgres)
DATABASE_URL=postgres://oneapi:oneapi@postgres:5432/oneapi

# LiteLLM Service
LITELLM_PORT=4000
LITELLM_LOG_LEVEL=info
LITELLM_CONFIG_PATH=/app/config/litellm.yaml

# Optional local inference backend (Ollama)
OLLAMA_HOST=http://ollama:11434
OLLAMA_HOST_2=http://ollama2:11434
